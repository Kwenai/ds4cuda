+/* =========================================================================
+ * CPU-path stage tensor dump (M1a alignment with ds4cuda).
+ *
+ * When DS4_CPU_DUMP_STAGES_DIR is set in the environment, the CPU prefill /
+ * decode paths emit one binary file per (layer, prompt-token, stage tag).
+ * This is a debug-only side channel; when the env var is unset, every
+ * dump call short-circuits via a single pointer test.
+ *
+ * File layout: 32-byte header followed by raw little-endian payload.
+ *
+ *   off  size  field
+ *   0    4     magic = "DSST"
+ *   4    4     version u32 = 1
+ *   8    4     dtype  u32 (0=fp32, 1=fp16, 2=int32)
+ *   12   8     n_elements u64
+ *   20   12    reserved (zero)
+ *
+ * File names: <DUMP_DIR>/il<LL>_tok<TT>_<tag>.bin
+ *
+ * DS4_CPU_DUMP_STAGES_LAYERS, when set to a comma-separated list of layer
+ * indices (e.g. "0,1"), restricts dumping to those layers.  Unset == dump
+ * every layer.
+ * ========================================================================= */
+
+#define DS4_CPU_DUMP_MAX_LAYER_FILTER 64
+
+static const char *ds4_cpu_dump_stages_dir = NULL;
+static int  ds4_cpu_dump_layer_filter[DS4_CPU_DUMP_MAX_LAYER_FILTER];
+static int  ds4_cpu_dump_layer_filter_count = 0;
+static bool ds4_cpu_dump_inited = false;
+
+static void ds4_cpu_dump_stage_init(void) {
+    if (ds4_cpu_dump_inited) return;
+    ds4_cpu_dump_inited = true;
+
+    const char *dir = getenv("DS4_CPU_DUMP_STAGES_DIR");
+    if (!dir || !dir[0]) {
+        ds4_cpu_dump_stages_dir = NULL;
+        return;
+    }
+    ds4_cpu_dump_stages_dir = dir;
+
+    const char *layers = getenv("DS4_CPU_DUMP_STAGES_LAYERS");
+    ds4_cpu_dump_layer_filter_count = 0;
+    if (layers && layers[0]) {
+        const char *p = layers;
+        while (*p && ds4_cpu_dump_layer_filter_count < DS4_CPU_DUMP_MAX_LAYER_FILTER) {
+            while (*p == ' ' || *p == ',') p++;
+            if (!*p) break;
+            char *end = NULL;
+            long v = strtol(p, &end, 10);
+            if (end == p) break;
+            if (v >= 0 && v < (long)DS4_N_LAYER) {
+                ds4_cpu_dump_layer_filter[ds4_cpu_dump_layer_filter_count++] = (int)v;
+            }
+            p = end;
+        }
+    }
+
+    fprintf(stderr, "ds4: CPU stage dump enabled, dir=%s, layers=", dir);
+    if (ds4_cpu_dump_layer_filter_count == 0) {
+        fprintf(stderr, "all\n");
+    } else {
+        for (int i = 0; i < ds4_cpu_dump_layer_filter_count; i++) {
+            fprintf(stderr, "%s%d", i ? "," : "", ds4_cpu_dump_layer_filter[i]);
+        }
+        fprintf(stderr, "\n");
+    }
+}
+
+static bool ds4_cpu_dump_stage_layer_active(uint32_t il) {
+    if (!ds4_cpu_dump_stages_dir) return false;
+    if (ds4_cpu_dump_layer_filter_count == 0) return true;
+    for (int i = 0; i < ds4_cpu_dump_layer_filter_count; i++) {
+        if ((int)il == ds4_cpu_dump_layer_filter[i]) return true;
+    }
+    return false;
+}
+
+static void ds4_cpu_dump_stage_unfiltered(
+        const char *tag,
+        uint32_t    il,
+        uint32_t    token_idx,
+        const void *data,
+        uint64_t    n_elements,
+        uint32_t    dtype) {
+    /* Same on-disk format as ds4_cpu_dump_stage but bypasses the
+     * DS4_CPU_DUMP_STAGES_LAYERS layer filter — used for the output head
+     * dumps which are emitted exactly once per prefill (after layer 42).
+     * The layer filter only constrains per-layer in-loop dumps. */
+    if (!ds4_cpu_dump_stages_dir || !data || n_elements == 0) return;
+
+    char path[1024];
+    snprintf(path, sizeof(path), "%s/il%02u_tok%02u_%s.bin",
+             ds4_cpu_dump_stages_dir, il, token_idx, tag);
+
+    FILE *fp = fopen(path, "wb");
+    if (!fp) {
+        fprintf(stderr, "ds4: cpu_dump_stage: failed to open %s: %s\n",
+                path, strerror(errno));
+        return;
+    }
+
+    uint8_t header[32];
+    memset(header, 0, sizeof(header));
+    header[0] = 'D'; header[1] = 'S'; header[2] = 'S'; header[3] = 'T';
+    uint32_t version = 1u;
+    memcpy(header + 4,  &version,    sizeof(version));
+    memcpy(header + 8,  &dtype,      sizeof(dtype));
+    memcpy(header + 12, &n_elements, sizeof(n_elements));
+
+    size_t elem_size = (dtype == 1) ? 2 : 4; /* fp16=2, fp32=4, int32=4 */
+    size_t total = (size_t)n_elements * elem_size;
+
+    bool ok = fwrite(header, 1, sizeof(header), fp) == sizeof(header);
+    if (ok) ok = fwrite(data, 1, total, fp) == total;
+    if (fclose(fp) != 0) ok = false;
+
+    if (!ok) {
+        fprintf(stderr, "ds4: cpu_dump_stage: failed to write %s\n", path);
+    }
+}
+
+static void ds4_cpu_dump_stage(
+        const char *tag,
+        uint32_t    il,
+        uint32_t    token_idx,
+        const void *data,
+        uint64_t    n_elements,
+        uint32_t    dtype) {
+    if (!ds4_cpu_dump_stage_layer_active(il)) return;
+    ds4_cpu_dump_stage_unfiltered(tag, il, token_idx, data, n_elements, dtype);
+}
